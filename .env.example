# Firebase (client — Vite needs VITE_ prefix)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=abta-member.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=abta-member
VITE_FIREBASE_STORAGE_BUCKET=abta-member
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# LINE Messaging API
LINE_MESSAGING_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_SECRET=
LINE_MESSAGING_ACCESS_TOKEN=

# LINE Login + LIFF
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
VITE_LIFF_ID=
VITE_LIFF_URL=

# Public web origin (Cloud Functions deep links)
WEB_ORIGIN=https://abta-member.web.app

# Membership fee (THB) — default 500 from mockup until customer confirms
MEMBERSHIP_FEE_THB=500

# Optional: comma-separated LINE userIds for staff new-registration alerts
# Leave empty to skip staff push
STAFF_LINE_USER_IDS=

# Admin SDK (local)
GOOGLE_APPLICATION_CREDENTIALS=./abta-member-firebase-adminsdk-*.json
